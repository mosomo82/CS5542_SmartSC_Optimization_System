# .env template - Copy to .env and fill in your values
SNOWFLAKE_ACCOUNT=your_account_locator
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=HYPERLOGISTICS_DB
SNOWFLAKE_SCHEMA=BRONZE

# AWS S3 Configuration (for automated loading)
AWS_REGION=us-east-1
S3_BUCKET=your-hyperlogistics-bucket

# Snowflake IAM Role ARN for S3 Access
# Format: arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_ROLE_NAME
# Example: arn:aws:iam::123456789012:role/SnowflakeS3Role
# To get this:
#   1. Run: python src/ingestion/validate_aws_role.bat (Windows) or ./validate_aws_role.sh (Linux)
#   2. Get your AWS Account ID from AWS Console (Account ID)
#   3. Create IAM role in AWS (or use existing one)
#   4. Replace below with your actual role ARN
SNOWFLAKE_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/SnowflakeS3Role